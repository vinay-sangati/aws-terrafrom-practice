# Used by docker-compose for the Postgres container only.
# Application settings live in config.yaml (copy from config.example.yaml).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
# Use 5433 if something else (e.g. local Postgres) already uses 5432
POSTGRES_PORT=5433
POSTGRES_DB=appdb

# Optional: override Secrets Manager secret id for DB password (ECS / CI)
# POSTGRES_PASSWORD_SECRET_ID=
# POSTGRES_PASSWORD_SECRET_JSON_KEY=password

# Optional: SNS topic for user.created (overrides config.yaml)
# SNS_USER_CREATED_TOPIC_ARN=

# Optional: pass into the api container for boto3 (not read by app Settings)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
