POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
# Use 5433 if something else (e.g. local Postgres) already uses 5432
POSTGRES_PORT=5433
POSTGRES_DB=appdb

# AWS SQS (POST /users publishes user.created; credentials via AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, profile, or IAM role)
AWS_REGION=us-east-1
# Optional LocalStack or custom endpoint:
# AWS_ENDPOINT_URL=http://localhost:4566
SQS_USER_CREATED_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-queue-name
